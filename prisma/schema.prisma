generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Novel {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  genre       String   @default("")
  coverImage  String   @default("")
  status      String   @default("draft")
  wordCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chapters        Chapter[]
  characters      Character[]
  worldSettings   WorldSetting[]
  agentTasks      AgentTask[]
  specs           NovelSpec[]
  changeProposals ChangeProposal[]
  snapshots       ChapterSnapshot[]
  branches        Branch[]
}

model Chapter {
  id            String   @id @default(cuid())
  novelId       String
  title         String   @default("")
  content       String   @default("")
  summary       String   @default("")
  chapterNumber Int      @default(1)
  status        String   @default("draft")
  wordCount     Int      @default(0)
  branchId      String   @default("main")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  novel      Novel        @relation(fields: [novelId], references: [id], onDelete: Cascade)
  agentTasks AgentTask[]
}

model Character {
  id          String   @id @default(cuid())
  novelId     String
  name        String
  role        String   @default("supporting")
  description String   @default("")
  personality String   @default("")
  appearance  String   @default("")
  backstory   String   @default("")
  avatarUrl   String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)
}

model WorldSetting {
  id          String   @id @default(cuid())
  novelId     String
  name        String
  category    String   @default("geography")
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)
}

model AgentTask {
  id           String   @id @default(cuid())
  novelId      String
  chapterId    String?
  agentType    String
  status       String   @default("pending")
  input        String   @default("")
  output       String   @default("")
  errorMessage String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  novel   Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
}

// ============================================================
// OpenSpec + SDD Engineering Version Management
// ============================================================

model NovelSpec {
  id          String   @id @default(cuid())
  novelId     String
  category    String   @default("outline")
  title       String
  content     String   @default("")
  version     Int      @default(1)
  status      String   @default("active")
  parentSpecId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  novel      Novel           @relation(fields: [novelId], references: [id], onDelete: Cascade)
  specDeltas SpecDelta[]
}

model SpecDelta {
  id          String   @id @default(cuid())
  specId      String
  proposalId  String?
  operation   String   @default("ADDED")
  description String   @default("")
  diffContent String   @default("")
  applied     Boolean  @default(false)
  appliedAt   DateTime?
  createdAt   DateTime @default(now())

  spec     NovelSpec      @relation(fields: [specId], references: [id], onDelete: Cascade)
  proposal ChangeProposal? @relation(fields: [proposalId], references: [id], onDelete: SetNull)
}

model ChangeProposal {
  id          String    @id @default(cuid())
  novelId     String
  title       String
  description String    @default("")
  scope       String    @default("")
  impact      String    @default("")
  tasks       String    @default("")
  status      String    @default("draft")
  completedAt DateTime?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  novel      Novel        @relation(fields: [novelId], references: [id], onDelete: Cascade)
  specDeltas SpecDelta[]
}

model ChapterSnapshot {
  id              String   @id @default(cuid())
  novelId         String
  chapterId       String?
  chapterNumber   Int      @default(0)
  snapshotType    String   @default("manual")
  label           String   @default("")
  chapterContent  String   @default("")
  specSnapshot    String   @default("")
  metadata        String   @default("")
  createdAt       DateTime @default(now())

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)
}

model Branch {
  id               String   @id @default(cuid())
  novelId          String
  name             String   @default("main")
  description      String   @default("")
  parentBranchId   String?
  basedOnSnapshotId String?
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)
}
